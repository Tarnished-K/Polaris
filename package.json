{
  "name": "warikan-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --exclude e2e",
    "test:e2e": "npm run build && playwright test",
    "test:watch": "vitest",
    "backend:start": "supabase start",
    "backend:stop": "supabase stop",
    "backend:reset": "supabase db reset",
    "backend:test": "supabase test db",
    "backend:test:linked": "node scripts/run-hosted-pgtap.mjs",
    "backend:lint": "supabase db lint --local",
    "backend:types": "supabase gen types typescript --linked --schema public > src/backend/database.types.ts",
    "backend:validate": "node scripts/validate-backend.mjs",
    "audit:lighthouse": "npm run build && node scripts/lighthouse-audit.mjs",
    "audit:lighthouse:update": "npm run build && node scripts/lighthouse-audit.mjs --update-baseline"
  },
  "dependencies": {
    "@sentry/react": "^10.67.0",
    "@supabase/supabase-js": "^2.110.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.4.1",
    "pg": "^8.22.0",
    "supabase": "^2.109.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
